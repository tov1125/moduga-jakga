# Supabase 설정
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# OpenAI 설정
OPENAI_API_KEY=your_openai_api_key

# CLOVA Speech (STT) 설정
CLOVA_SPEECH_SECRET=your_clova_speech_secret
CLOVA_SPEECH_INVOKE_URL=your_clova_speech_invoke_url

# CLOVA Voice (TTS) 설정
CLOVA_VOICE_CLIENT_ID=your_clova_voice_client_id
