{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "${BACKEND_URL}/api/v1/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "${BACKEND_URL}/static/:path*"
    }
  ]
}
